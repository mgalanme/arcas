# /home/pruebas/formacion/arcas/.env.example
# Copy to .env and fill in your values. NEVER commit .env to Git.
 
# ── LLM ──────────────────────────────────────────────────────────────────────
GROQ_API_KEY=gsk_YOUR_GROQ_KEY_HERE
GROQ_MODEL_PRIMARY=llama-3.3-70b-versatile
GROQ_MODEL_FALLBACK=llama-3.1-8b-instant
 
# ── Observability ──────────────────────────────────────────────────────────────
LANGSMITH_API_KEY=ls__YOUR_LANGSMITH_KEY_HERE
LANGSMITH_PROJECT=arcas
LANGSMITH_TRACING=true
 
# ── Embeddings ────────────────────────────────────────────────────────────────
HF_TOKEN=hf_YOUR_HF_TOKEN_HERE
EMBEDDING_MODEL=nomic-ai/nomic-embed-text-v1
EMBEDDING_DIMS=768
 
# ── Databases ────────────────────────────────────────────────────────────────
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_DB=arcas
POSTGRES_USER=arcas_app
POSTGRES_PASSWORD=CHANGE_ME_postgres
 
NEO4J_URI=bolt://localhost:7687
NEO4J_USER=neo4j
NEO4J_PASSWORD=CHANGE_ME_neo4j
NEO4J_PLUGINS=["apoc"]
 
QDRANT_HOST=localhost
QDRANT_PORT=6333
 
REDIS_URL=redis://localhost:6379
 
MINIO_ENDPOINT=localhost:9000
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=CHANGE_ME_minio
MINIO_BUCKET_RAW=arcas-raw
MINIO_BUCKET_ICEBERG=arcas-iceberg
 
# ── Kafka ─────────────────────────────────────────────────────────────────────
KAFKA_BOOTSTRAP=localhost:9092
KAFKA_SCHEMA_REGISTRY=http://localhost:8081
 
# ── Databricks ───────────────────────────────────────────────────────────────
DATABRICKS_HOST=https://community.cloud.databricks.com
DATABRICKS_TOKEN=dapiYOUR_DATABRICKS_TOKEN_HERE
 
# ── Solace Agent Mesh ──────────────────────────────────────────────────────────
SAM_BROKER_URL=localhost:55555
SAM_USERNAME=admin
SAM_PASSWORD=CHANGE_ME_sam
 
# ── Infisical (self-hosted) ───────────────────────────────────────────────────
INFISICAL_TOKEN=st.YOUR_INFISICAL_TOKEN_HERE
INFISICAL_HOST=http://localhost:8080
 
# ── Application ──────────────────────────────────────────────────────────────
ARCAS_ENV=development
ARCAS_LOG_LEVEL=INFO
ARCAS_PSEUDONYM_SALT=CHANGE_ME_use_long_random_string
ARCAS_AUDIT_HMAC_KEY=CHANGE_ME_use_long_random_string
